pipeline {
    agent any

    stages {
        stage('Clone Repo') {
            steps {
                git branch: 'main', url: 'https://github.com/Mohan-mk06/Library-Management-system.git'
            }
        }
        stage('Install Dependencies') {
            steps {
                dir('Agille') {
                    bat 'npm install' 
                }
            }
        }
        stage('Build Docker Image') {
            steps {
                dir('Agille') {
                    bat 'docker build -t library-app .' 
                }
            }
        }
        stage('Deploy to Kubernetes') {
            steps {
                dir('Agille') {
                    // Load the image into Minikube so it doesn't get an ImagePullBackOff error
                    bat 'minikube image load library-app'
                    
                    // Deploy the app and service using the YAML file
                    bat 'kubectl apply -f deployment.yaml'
                }
            }
        }
    }
}
